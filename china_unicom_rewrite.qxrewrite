# 中国联通 获取 Cookie 重写规则
# 适用于 Quantumult X



[mitm]
hostname = *.10010.com, *.chinaunicom.cn

[rewrite_local]
^https?:\/\/.*10010\.com\/.* url script-request-header https://raw.githubusercontent.com/enkiger/Proxies/refs/heads/main/china_unicom_cookie.js
^https?:\/\/.*chinaunicom\.cn\/.* url script-request-header https://raw.githubusercontent.com/enkiger/Proxies/refs/heads/main/china_unicom_cookie.js
